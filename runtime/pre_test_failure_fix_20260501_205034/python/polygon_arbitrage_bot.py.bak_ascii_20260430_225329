                    # Phase 4: Execution
                    logger.info("âš¡ PHASE 4: EXECUTION PHASE")
                    executed_count = 0

                    for opp in optimized_opps:
                        if opp.estimated_profit_usd > 10:  # Minimum profit threshold
                            logger.info(f"   ðŸŽ¯ EXECUTING OPPORTUNITY:")
                            logger.info(f"      â€¢ Token: {opp.token}")
                            logger.info(f"      â€¢ Expected Profit: ${opp.estimated_profit_usd:.2f}")
                            logger.info(f"      â€¢ Flash Loan Amount: ${opp.flash_loan_amount:,.0f}")

