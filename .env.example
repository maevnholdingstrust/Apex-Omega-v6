# Apex-Omega v6 master environment template
# Copy to .env locally. Never commit real secrets.

# ---------------------------------------------------------------------------
# Chain
# ---------------------------------------------------------------------------
CHAIN_ID=137
ENVIRONMENT=development
LIVE_TRADING_ENABLED=false
DRY_RUN=true

# ---------------------------------------------------------------------------
# Polygon RPC endpoints
# ---------------------------------------------------------------------------
POLYGON_RPC=
POLYGON_HTTP=
POLYGON_WSS=
PRIVATE_RPC_URL=
RPC_REQUEST_TIMEOUT_SEC=10

ALCHEMY_HTTP_1=
ALCHEMY_HTTP_2=
ALCHEMY_WSS_1=
ALCHEMY_WSS_2=
INFURA_HTTP=
INFURA_WSS=
PUBLIC_DRPC=

# ---------------------------------------------------------------------------
# MEV / private relay endpoints
# ---------------------------------------------------------------------------
TITAN_MEV_US_WEST=https://rpc.titanbuilder.xyz
FASTLANE_RELAY=
MARLIN_RELAY=
FLASHBOTS_RELAY=
BUNDLE_TARGET_BLOCK_OFFSET=1
BUNDLE_MAX_BLOCK_WINDOW=5

# ---------------------------------------------------------------------------
# Wallet and signing
# ---------------------------------------------------------------------------
EXECUTOR_PRIVATE_KEY=
BUNDLE_SIGNER_PRIVATE_KEY=
OPERATOR_ADDRESS=
PROFIT_RECIPIENT_ADDRESS=

# ---------------------------------------------------------------------------
# Deployed executor contracts on Polygon
# ---------------------------------------------------------------------------
C1_INSTITUTIONAL_EXECUTOR_ADDRESS=
C2_ULTIMATE_ARBITRAGE_EXECUTOR_ADDRESS=
AAVE_V3_POOL_ADDRESS=0x794a61358D6845594F94dc1Db02A252b5b4814aD
BALANCER_VAULT_ADDRESS=0xBA12222222228d8Ba445958a75a0704d566BF2C8

# ---------------------------------------------------------------------------
# Risk gates and execution thresholds
# ---------------------------------------------------------------------------
MIN_NET_PROFIT_USD=1.00
MIN_RAW_SPREAD_BPS=1.00
MAX_ROUTE_SLIPPAGE_BPS=100.00
MAX_MEMPOOL_DEGRADATION_BPS=200.00
MIN_POOL_TVL_USD=10000.00
MAX_TRADE_TO_POOL_RATIO_BPS=500.00
RISK_BUFFER_USD=0.00

# ---------------------------------------------------------------------------
# Cost model
# ---------------------------------------------------------------------------
C1_GAS_USD=0.38
C2_GAS_USD=0.55
FLASH_LOAN_FEE_BPS=5.00
MAX_FEE_PER_GAS_GWEI=
MAX_PRIORITY_FEE_PER_GAS_GWEI=

# ---------------------------------------------------------------------------
# Dashboard/API
# ---------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8080
WEBSOCKET_HOST=127.0.0.1
WEBSOCKET_PORT=8090
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Logging / audit
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
OPPORTUNITY_LOG_PATH=logs/opportunities.jsonl
REJECTION_LOG_PATH=logs/rejections.jsonl
AUDIT_LOG_PATH=logs/audit.jsonl
