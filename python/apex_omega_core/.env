# Apex-Omega local development environment template.
# Do NOT commit real credentials to this file.

# Network access
POLYGON_RPC=https://polygon-rpc.com/
POLYGON_HTTP=https://polygon-rpc.com/
POLYGON_WSS=wss://polygon-rpc.com/
APEX_RPC_URL=https://polygon-rpc.com/
APEX_WSS_URL=wss://polygon-rpc.com/

# Signing (leave empty for safe dry-runs)
PRIVATE_KEY=
OWNER_PRIVATE_KEY=
RELAY_AUTH_KEY=
POLYGONSCAN_API_KEY=

# Execution addresses (replace per deployment)
CHAIN_ID=137
NETWORK=polygon
EXECUTOR_C1_ADDRESS=
EXECUTOR_C2_ADDRESS=
ROUTER_QUICKSWAP=
ROUTER_UNISWAP_V3=

# Safety defaults for local and CI dry-runs
APEX_SEND_TX=0
APEX_WAIT_RECEIPT=0
ENABLE_BUNDLE_MODE=0
SAFE_GAS_MULTIPLIER=1.0

# Pricing defaults used by tests/import-time config
APEX_POL_USD=0.85
APEX_ETH_USD=3500
